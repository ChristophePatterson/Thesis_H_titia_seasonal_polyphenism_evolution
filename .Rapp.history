m4k10 <- brm(#
  bf(#
    proportion.pigmented ~ #
      CLUSTER +#
      s(Julian.date, by = CLUSTER, bs = "cc", k = 10) +#
      (1 | site.id),#
    phi ~ s(Julian.date, by=CLUSTER, bs = "cc", k = 10)#
  ),#
  knots = list(Julian.date = c(1, 365)),#
  family = zero_one_inflated_beta(),#
  data = titsub,#
  chains = 4, cores = 4,#
  control = list(adapt_delta = 0.9)#
)
m4k9 <- brm(#
  bf(#
