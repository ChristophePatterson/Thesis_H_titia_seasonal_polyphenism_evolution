newdat$predicted.var<-var_pred <- mu * (1 - mu) / (1 + phi)#
#
new_palette <- c(#
  # Blues (2)#
  rgb(0.00, 0.10, 0.70),  # blue, A#
  rgb(0.20, 0.50, 1.00),  # lighter blue, B#
  # Greens (5) — wider spread in lightness + slight hue variation#
  rgb(0.25, 0.55, 0.00),  # dark olive-green, C#
  rgb(0.35, 0.70, 0.00),  # strong green, G#
  rgb(0.50, 0.80, 0.00),  # chartreuse3-like, E#
  rgb(0.65, 0.90, 0.15),  # light yellow-green, D#
  rgb(0.80, 0.95, 0.40),  # very pale chartreuse, H #
  # Orange (1)#
  rgb(0.93, 0.49, 0.20) #F#
)#
#
ggplot(titsub,aes(x=Julian.date,y=proportion.pigmented,group=CLUSTER,col=CLUSTER))+geom_point(alpha=0.2)+scale_colour_manual(values=new_palette[c(1:3,7,5,8,4,6)])+geom_line(data = newdat, aes(x = Julian.date, y = predicted.pp), col="black",lwd = 1)+geom_hline(yintercept=c(0.5),lty=2)+facet_wrap(~CLUSTER)+theme_classic()+ylim(c(0,1))
