A <- vcv(tree.phylo)
m4k8_zi_phyloBM <- brm(#
  bf(#
    proportion.pigmented ~ #
      CLUSTER +#
      s(Julian.date, by = CLUSTER, bs = "cc", k = 8) +#
      (1 | site.id)+ (1 | gr(CLUSTER, cov = A)),#
    phi ~ s(Julian.date, by=CLUSTER, bs = "cc", k = 8),#
    zoi ~ s(Julian.date, by=CLUSTER, bs = "cc", k = 8)#
  ),#
  knots = list(Julian.date = c(1, 365)),#
  family = zero_one_inflated_beta(),#
  data = titsub,#
  data2 = list(A = A),#
  chains = 4, cores = 4,#
  save_pars = save_pars(all = TRUE),#
  control = list(max_treedepth=15,adapt_delta = 0.99),#
  iter = getOption("brms.iter", 3000)#
#
)#
